# ══════════════════════════════════════════
# Telegram Bot v2.0 — Environment Variables
# ══════════════════════════════════════════

# ─── Telegram Bot ─────────────────────────────
BOT_TOKEN=your_bot_token_here

# Telegram IDs của admin (phân cách bằng dấu phẩy)
ADMIN_IDS=123456789,987654321

# ─── Server ───────────────────────────────────
PORT=3000
NODE_ENV=development

# URL public của server (dùng cho webhook production)
# Ví dụ: https://yourapp.railway.app
BASE_URL=https://your-domain.com

# ─── Database — Supabase PostgreSQL ───────────
# Lấy từ: Supabase Dashboard → Project Settings → Database → Connection string
# "Transaction pooler" (port 6543) → DATABASE_URL
# "Session pooler" hoặc Direct    → DIRECT_URL

DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Payment — VietQR & Bank Info ─────────────
BANK_CODE=TCB
BANK_NAME=Techcombank
BANK_ACCOUNT=your_account_number
BANK_ACCOUNT_NAME=YOUR_NAME

# ─── Payment — SePay Webhook ──────────────────
# Lấy từ: https://my.sepay.vn → API Settings
SEPAY_MERCHANT_ID=SP-LIVE-XXXXXXXX
SEPAY_SECRET_KEY=spsk_live_xxxxxxxxxxxxx

# Secret token để verify webhook signature (tự đặt bất kỳ chuỗi ngẫu nhiên)
IPN_SECRET_TOKEN=your_random_secret_token_here

# ─── Referral ─────────────────────────────────
REFERRAL_COMMISSION_RATE=5

# ─── Logging ──────────────────────────────────
# trace | debug | info | warn | error
LOG_LEVEL=info

# Telegram channel ID để gửi log lỗi (optional, để trống nếu không dùng)
LOG_CHANNEL_ID=

# ─── Admin Features ───────────────────────────
# Secret cho endpoint seed dữ liệu ban đầu
ADMIN_SECRET=your_seed_secret_here

# ─── Low Stock Alert ──────────────────────────
# Cảnh báo khi tồn kho sản phẩm xuống dưới ngưỡng này
LOW_STOCK_THRESHOLD=5
