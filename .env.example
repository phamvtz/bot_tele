# ============================================================
# Telegram Shop Bot — Environment Variables
# Copy file này thành .env và điền giá trị thật.
# KHÔNG commit file .env (đã ignore trong .gitignore).
# ============================================================

# --- Bot Telegram (bắt buộc) ---
# Lấy từ @BotFather. Có thể chỉ cần BOT_TOKEN, TELEGRAM_BOT_TOKEN là alias.
BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram ID admin, phân tách bằng dấu phẩy. Lấy từ @userinfobot
ADMIN_IDS=123456789

# Chat ID nhận thông báo hệ thống (thường giống ADMIN_IDS đầu tiên)
TELEGRAM_CHAT_ID=123456789

# Channel nhận thông báo đơn hàng tự động (ID hoặc @username)
ORDER_NOTIFY_CHANNEL=@vpluschannelkh

# Link channel hỗ trợ khách hàng — hiện nút trong tin nhắn giao hàng
SUPPORT_CHANNEL_URL=https://t.me/vpluschannelkh

# --- Server ---
PORT=3001

# Banner ảnh hiện khi /start (URL ảnh hoặc để trống)
SHOP_BANNER_URL=

# Webhook URL (nếu deploy có domain HTTPS, ngược lại để trống = polling mode)
WEBHOOK_URL=

# --- Database (bắt buộc) ---
# MongoDB Atlas connection string. Bot CHẠY THỰC TẾ trên MongoDB qua adapter,
# KHÔNG phải Postgres dù schema.prisma khai báo postgresql.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB=shopbottele
# DNS servers cho MongoDB (mặc định 8.8.8.8,1.1.1.1)
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# --- Tài khoản ngân hàng nhận tiền (bắt buộc) ---
BANK_CODE=MB
BANK_NAME=MB Bank
BANK_ACCOUNT=0000000000
BANK_ACCOUNT_NAME=NGUYEN VAN A

# Hiển thị fallback ở trang shop khi BANK_* trống
DEFAULT_BANK_NAME=MB Bank
DEFAULT_BANK_ACCOUNT=0000000000
DEFAULT_BANK_OWNER=NGUYEN VAN A

# --- Auto-confirm thanh toán (chọn 1 hoặc cả 2) ---
# Cách 1: Bank polling (chủ động fetch lịch sử mỗi 5s)
MBBANK_API_TOKEN=your_mbbank_api_token
MBBANK_HISTORY_BASE=https://thueapibank.vn/historyapimbbank
# BANK_POLL_ENABLED=true
# BANK_POLL_INTERVAL_MS=5000

# Cách 2: IPN webhook từ Casso/SePay (push về POST /webhook/ipn)
IPN_SECRET_TOKEN=your_ipn_secret_token
SEPAY_MERCHANT_ID=
SEPAY_SECRET_KEY=

# --- Bảo mật ---
# Bảo vệ endpoint admin (/admin/seed, /api/admin/icon-overrides)
ADMIN_SECRET=change_me_to_a_random_string

# --- Liên hệ ---
ADMIN_TELEGRAM=your_username

# --- Log bot phụ (tùy chọn) ---
# Tạo bot phụ và channel riêng để nhận log realtime
LOG_BOT_TOKEN=
LOG_CHANNEL_ID=

# --- Referral & limits ---
REFERRAL_COMMISSION=5
BACKUP_DIR=./backups
MAX_BACKUPS=10
EXPORT_DIR=./exports
