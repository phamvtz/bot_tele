# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789

# Server
PORT=3000
BASE_URL=https://your-domain.com

# Database (PostgreSQL - Neon.tech)
# DATABASE_URL = pooled connection (for app)
# DIRECT_URL = non-pooled connection (for prisma migrate/push)
DATABASE_URL=postgresql://user:pass@host.neon.tech/db?sslmode=require
DIRECT_URL=postgresql://user:pass@host.neon.tech/db?sslmode=require

# Bank Transfer - VietQR
BANK_CODE=TCB
BANK_NAME=Techcombank
BANK_ACCOUNT=your_account_number
BANK_ACCOUNT_NAME=YOUR NAME

# SePay Config (from https://my.sepay.vn)
SEPAY_MERCHANT_ID=SP-LIVE-XXXXXXXX
SEPAY_SECRET_KEY=spsk_live_xxxxxxxxxxxxx

# IPN Webhook Secret (optional, for signature verification)
IPN_SECRET_TOKEN=your_secret_token

# Referral
REFERRAL_COMMISSION=5

# Backup
BACKUP_DIR=./backups
MAX_BACKUPS=10

# Export
EXPORT_DIR=./exports
