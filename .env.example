# ============================================================
# Telegram Shop Bot — Environment Variables
# Copy file này thành .env và điền giá trị thật.
# KHÔNG commit file .env (đã ignore trong .gitignore).
# ============================================================

# --- Bot Telegram (bắt buộc) ---
# Lấy từ @BotFather. Có thể chỉ cần BOT_TOKEN, TELEGRAM_BOT_TOKEN là alias.
BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram ID admin, phân tách bằng dấu phẩy. Lấy từ @userinfobot
ADMIN_IDS=123456789

# Chat ID nhận thông báo hệ thống (thường giống ADMIN_IDS đầu tiên)
TELEGRAM_CHAT_ID=123456789

# Channel nhận thông báo đơn hàng tự động (ID hoặc @username)
ORDER_NOTIFY_CHANNEL=@vpluschannelkh

# Link channel hỗ trợ khách hàng — hiện nút trong tin nhắn giao hàng
SUPPORT_CHANNEL_URL=https://t.me/vpluschannelkh

# --- Cổng bắt buộc tham gia nhóm (onboarding) ---
# Khi bật, khách bấm /start phải chọn ngôn ngữ và tham gia nhóm trước khi dùng bot.
# REQUIRED_GROUP: @username kênh/nhóm. Bot PHẢI là admin của nhóm này để check được.
# Nếu bot không check được (chưa là admin), hệ thống cho qua để tránh khoá nhầm khách.
REQUIRED_GROUP=@vpluschannelkh
REQUIRED_GROUP_URL=https://t.me/vpluschannelkh
REQUIRE_GROUP_JOIN=true
# Bot PHẢI là admin của REQUIRED_GROUP để đọc được danh sách thành viên (getChatMember).
# GROUP_GATE_FAILOPEN=true: nếu bot không kiểm tra được thì CHO QUA (tránh khoá nhầm). Mặc định false = CHẶN.
# GROUP_GATE_ADMIN_BYPASS=true: admin luôn bỏ qua cổng. Mặc định false.
GROUP_GATE_FAILOPEN=false
GROUP_GATE_ADMIN_BYPASS=false

# --- Server ---
PORT=3001

# Banner ảnh hiện khi /start (URL ảnh hoặc để trống)
SHOP_BANNER_URL=

# Webhook URL (nếu deploy có domain HTTPS, ngược lại để trống = polling mode)
# Có thể ép polling bằng BOT_MODE=polling hoặc WEBHOOK_ENABLED=false.
BOT_MODE=polling
WEBHOOK_ENABLED=false
WEBHOOK_FALLBACK_POLLING=true
WEBHOOK_URL=

# Telegram transport. Keep-alive is disabled by default because stale TLS sockets
# can cause ECONNRESET/socket hang up during file uploads on Windows VPS.
TELEGRAM_KEEP_ALIVE=false
TELEGRAM_MAX_SOCKETS=16
TELEGRAM_SEND_RETRY_ATTEMPTS=6
TELEGRAM_DOCUMENT_RETRY_ATTEMPTS=2

# --- Database (bắt buộc) ---
# MongoDB Atlas connection string. Bot CHẠY THỰC TẾ trên MongoDB qua adapter,
# KHÔNG phải Postgres dù schema.prisma khai báo postgresql.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB=shopbottele
# DNS servers cho MongoDB (mặc định 8.8.8.8,1.1.1.1)
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# --- Tài khoản ngân hàng nhận tiền (bắt buộc) ---
BANK_CODE=MB
BANK_NAME=MB Bank
BANK_ACCOUNT=0000000000
BANK_ACCOUNT_NAME=NGUYEN VAN A

# Hiển thị fallback ở trang shop khi BANK_* trống
DEFAULT_BANK_NAME=MB Bank
DEFAULT_BANK_ACCOUNT=0000000000
DEFAULT_BANK_OWNER=NGUYEN VAN A

# --- Auto-confirm thanh toán (chọn 1 hoặc cả 2) ---
# Cách 1: Bank polling (chủ động fetch lịch sử mỗi 5s)
MBBANK_API_TOKEN=your_mbbank_api_token
MBBANK_HISTORY_BASE=https://thueapibank.vn/historyapimbbank
# BANK_POLL_ENABLED=true
# BANK_POLL_INTERVAL_MS=5000

# Cách 2: IPN webhook từ Casso/SePay (push về POST /webhook/ipn)
IPN_SECRET_TOKEN=your_ipn_secret_token
SEPAY_MERCHANT_ID=
SEPAY_SECRET_KEY=

# Cách 3: USDT crypto auto-confirm
# Bot quy đổi VND -> USDT theo tỷ giá này, rồi thêm phần lẻ riêng cho từng đơn để tự khớp.
CRYPTO_PAY_ENABLED=true
CRYPTO_POLL_ENABLED=true
CRYPTO_POLL_INTERVAL_MS=15000
CRYPTO_AMOUNT_TOLERANCE=0.0000004
CRYPTO_EXPIRE_MINUTES=20
# true = tu cap nhat ty gia USDT/VND theo thi truong; CRYPTO_USD_VND_RATE chi la gia du phong.
CRYPTO_USD_VND_RATE_AUTO=true
CRYPTO_USD_VND_RATE=26500
CRYPTO_USD_CNY_RATE=7.25
CRYPTO_USD_VND_RATE_UPDATE_MS=300000
CRYPTO_MIN_DEPOSIT_USDT=1
TRC20_USDT_ADDRESS=
BEP20_USDT_ADDRESS=
TRONGRID_API_KEY=
BSCSCAN_API_KEY=
BANK_AMOUNT_TOLERANCE_VND=0

# --- Bảo mật ---
# Bảo vệ endpoint admin (/admin/seed, /api/admin/icon-overrides)
ADMIN_SECRET=change_me_to_a_random_string

# --- Liên hệ ---
ADMIN_TELEGRAM=your_username

# --- Log bot phụ (tùy chọn) ---
# Tạo bot phụ và channel riêng để nhận log realtime
LOG_BOT_TOKEN=
LOG_CHANNEL_ID=

# --- Referral & limits ---
REFERRAL_COMMISSION=5
BACKUP_DIR=./backups
MAX_BACKUPS=10
EXPORT_DIR=./exports
